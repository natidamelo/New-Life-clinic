{
  "name": "clinic-cms-backend",
  "version": "1.0.0",
  "description": "Backend for Clinic Management System",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0 <23.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "telegram": "node telegram-server.js",
    "start:managed": "node start-server.js start",
    "stop": "node start-server.js stop",
    "status": "node start-server.js status",
    "restart": "node start-server.js restart",
    "dev": "nodemon server.js",
    "build": "echo 'Backend build completed - Node.js application ready for production'",
    "build:check": "node -c server.js && echo 'Syntax check passed'",
    "build:prod": "cross-env NODE_ENV=production node server.js",
    "build:indexes": "node scripts/buildIndexes.js",
    "verify:indexes": "node scripts/verifyIndexes.js",
    "test": "jest"
  },
  "keywords": [
    "clinic",
    "management",
    "backend"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.12.2",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.0.1",
    "express-validator": "^7.2.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^7.5.0",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "node-fetch": "^3.3.2",
    "node-telegram-bot-api": "^0.66.0",
    "pdfkit": "^0.17.2",
    "qrcode": "^1.5.4",
    "semver": "^7.5.4",
    "socket.io": "^4.7.2",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "nodemon": "^3.0.1"
  }
}
