TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MONGODB_URI=mongodb://localhost:27017/clinic-cms
# Set to true to skip startup backfill of missing clinicId across all collections
# SKIP_CLINIC_ID_BACKFILL=false
# Optional: comma-separated collection names to skip (lowercase), default skips "clinics"
# CLINIC_ID_BACKFILL_SKIP_COLLECTIONS=clinics
# Tenant reads always merge your slug + PRIMARY + default + unstamped (legacy Atlas rows without clinicId).
# Match your Atlas users’ clinicId (e.g. clinicnew). Backfill stamps missing rows with this; reads also match it + default + legacy.
# PRIMARY_CLINIC_ID=default
# After a backfill used "default", set PRIMARY_CLINIC_ID=clinicnew and enable once to rewrite default → clinicnew
# NORMALIZE_DEFAULT_CLINIC_ID=false
NODE_ENV=development
PORT=5002
JWT_SECRET=your_jwt_secret_key_here
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change_this_secure_password
SUPER_ADMIN_EMAIL=superadmin@clinic.local

# One-time: migrate tenant clinicId from legacy "default" to your clinic slug (e.g. clinic)
# MIGRATE_SOURCE=default
# MIGRATE_TARGET=clinic
# DRY_RUN=true
# SKIP_CLINIC_CHECK=false

# AI Features - Get your free API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
