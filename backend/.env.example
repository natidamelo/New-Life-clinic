TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
MONGODB_URI=mongodb://localhost:27017/clinic-cms
NODE_ENV=development
PORT=5002
JWT_SECRET=your_jwt_secret_key_here
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_PASSWORD=change_this_secure_password
SUPER_ADMIN_EMAIL=superadmin@clinic.local

# One-time: migrate tenant clinicId from legacy "default" to your clinic slug (e.g. clinic)
# MIGRATE_SOURCE=default
# MIGRATE_TARGET=clinic
# DRY_RUN=true
# SKIP_CLINIC_CHECK=false

# AI Features - Get your free API key from https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here
