# Frontend Environment Variables  
# Copy this file to .env and update with your values  
  
# Backend API URL - Use your computer's hostname or static IP  
# Example: http://DESKTOP-DC2ICOB:5002  
# For Vercel: set the same variable in Project Settings → Environment Variables
# (must be a public HTTPS URL, e.g. https://your-api.onrender.com — not 192.168.x.x)
# Leave empty for local dev (Vite proxies /api to localhost:5002)
VITE_API_URL=
